#!/bin/bash
# CyberNord MOTD v6 — maximum information density, parallel execution
# Panels: identity, system bars, top procs, docker+health, services,
#         security, network, updates, HTB, WG mesh+latency, sessions, warnings

set -uo pipefail

# ── Colors ──────────────────────────────────────────────────────────────
R='\033[1;31m'   r='\033[0;31m'
G='\033[1;32m'   g='\033[0;32m'
Y='\033[1;33m'
B='\033[1;34m'
M='\033[1;35m'
C='\033[1;36m'
W='\033[1;37m'
D='\033[0;90m'
N='\033[0m'

LINE="${D}  $(printf '─%.0s' {1..74})${N}"

# ── Node identity ──────────────────────────────────────────────────────
WG_IF=$(ip -o link show type wireguard 2>/dev/null | head -1 | awk -F: '{print $2}' | tr -d ' ')
MY_WG_IP=""
[ -n "$WG_IF" ] && MY_WG_IP=$(ip -4 addr show "$WG_IF" 2>/dev/null | grep -oP 'inet \K[0-9.]+')

case "$MY_WG_IP" in
  10.10.0.1) NC_COLOR="$R"; NODE_ROLE="storage · docker hub"; NODE_ICON="◆" ;;
  10.10.0.2) NC_COLOR="$M"; NODE_ROLE="compute · secondary";  NODE_ICON="◇" ;;
  10.10.0.4) NC_COLOR="$G"; NODE_ROLE="gpu · browser";         NODE_ICON="▣" ;;
  *)         NC_COLOR="$C"; NODE_ROLE="node";                   NODE_ICON="○" ;;
esac

HOSTNAME_STR=$(hostname)
OS=$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || uname -s)
PRIMARY_IP=$(ip -4 route get 1.1.1.1 2>/dev/null | grep -oP 'src \K[0-9.]+' || hostname -I 2>/dev/null | awk '{print $1}')
KERNEL=$(uname -r | sed 's/-generic//' | cut -d- -f1)
WG_STATUS="down"; [ -n "$WG_IF" ] && WG_STATUS="up"

# ── Parallel data collection ──────────────────────────────────────────
# Launch background jobs for slow operations
{
  # Tailscale IP
  TS_IP=$(ip -4 addr show tailscale0 2>/dev/null | grep -oP 'inet \K[0-9.]+')
  echo "TS_IP=${TS_IP:-none}" > /tmp/.motd-ts
} &

{
  # Top 3 processes by CPU
  ps aux --no-header --sort=-%cpu 2>/dev/null | head -3 | awk '{printf "%s %.0f%% %.0f%% %s\n", $1, $3, $4, $11}' > /tmp/.motd-procs
} &

{
  # Network rate (0.3s sample)
  ETH_IF=$(ip -4 route get 1.1.1.1 2>/dev/null | grep -oP 'dev \K\S+')
  if [ -n "$ETH_IF" ]; then
    read RX1 TX1 < <(awk -v i="$ETH_IF:" '$1==i{print $2,$10}' /proc/net/dev)
    sleep 0.3
    read RX2 TX2 < <(awk -v i="$ETH_IF:" '$1==i{print $2,$10}' /proc/net/dev)
    echo "ETH_IF=$ETH_IF RX=$((( RX2-RX1)*10/3)) TX=$(((TX2-TX1)*10/3))" > /tmp/.motd-net
  fi
} &

{
  # SSH failed attempts (24h)
  F=$(journalctl -u ssh -u sshd --since "24 hours ago" 2>/dev/null | grep -c "Failed password\|authentication failure" 2>/dev/null || echo 0)
  F=${F%%$'\n'*}; F=$((F + 0))
  echo "$F" > /tmp/.motd-sshfail
} &

{
  # Pending updates
  if [ -f /usr/lib/update-notifier/apt-check ]; then
    /usr/lib/update-notifier/apt-check 2>&1 > /tmp/.motd-updates || echo "0;0" > /tmp/.motd-updates
  else
    echo "0;0" > /tmp/.motd-updates
  fi
} &

{
  # Ping all mesh peers in parallel
  for name_ip in "contabo-vps:10.10.0.1" "hostinger-vps:10.10.0.2" "windows-pc:10.10.0.3" "thinkpad-t14:10.10.0.4"; do
    name=${name_ip%%:*}; ip=${name_ip#*:}
    [ "$ip" = "$MY_WG_IP" ] && continue
    ( lat=$(ping -c1 -W1 "$ip" 2>/dev/null | grep -oP 'time=\K[0-9.]+') && echo "$lat" || echo "FAIL" ) > "/tmp/.motd-ping-$name" &
  done
  wait
} &

# ── System stats (fast — /proc reads) ─────────────────────────────────
CPU_CORES=$(nproc)
read LOAD1 LOAD5 LOAD15 _ _ < /proc/loadavg

MEM_TOTAL_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
MEM_AVAIL_KB=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
MEM_USED_KB=$((MEM_TOTAL_KB - MEM_AVAIL_KB))
MEM_TOTAL_MB=$((MEM_TOTAL_KB / 1024))
MEM_USED_MB=$((MEM_USED_KB / 1024))
MEM_PCT=$((MEM_USED_KB * 100 / MEM_TOTAL_KB))

DISK_INFO=$(df -h / | tail -1)
DISK_USED=$(echo "$DISK_INFO" | awk '{print $3}')
DISK_TOTAL=$(echo "$DISK_INFO" | awk '{print $2}')
DISK_PCT=$(echo "$DISK_INFO" | awk '{gsub(/%/,""); print $5}')

SWAP_TOTAL=$(grep SwapTotal /proc/meminfo | awk '{print $2}')
SWAP_PCT=0
[ "$SWAP_TOTAL" -gt 0 ] && {
  SWAP_FREE=$(grep SwapFree /proc/meminfo | awk '{print $2}')
  SWAP_PCT=$(( (SWAP_TOTAL - SWAP_FREE) * 100 / SWAP_TOTAL ))
}

UPTIME_SEC=$(awk '{print int($1)}' /proc/uptime)
UD=$((UPTIME_SEC/86400)); UH=$(((UPTIME_SEC%86400)/3600)); UM=$(((UPTIME_SEC%3600)/60))
[ "$UD" -gt 0 ] && UPTIME_STR="${UD}d ${UH}h ${UM}m" || UPTIME_STR="${UH}h ${UM}m"
PROCS=$(ls -d /proc/[0-9]* 2>/dev/null | wc -l)

# CPU temperature
CPU_TEMP=""
for tz in /sys/class/thermal/thermal_zone*/temp; do
  [ -f "$tz" ] && { t=$(cat "$tz"); [ "$t" -gt 0 ] && CPU_TEMP="$((t/1000))°C" && break; }
done

# Disk I/O (sectors since boot → human readable)
DISK_DEV=$(lsblk -ndo NAME / 2>/dev/null || echo "sda")
[ -z "$DISK_DEV" ] && DISK_DEV="sda"

# Active sessions
SESSIONS=$(who 2>/dev/null | wc -l)
LAST_LOGIN=$(last -1 -w 2>/dev/null | head -1 | awk '{print $3, $4, $5, $6}')

# Failed systemd services
FAILED_SVCS=$(systemctl --failed --no-pager --no-legend 2>/dev/null || true)
FAILED_COUNT=$(echo "$FAILED_SVCS" | grep -c "●" 2>/dev/null || echo 0); FAILED_COUNT=${FAILED_COUNT%%$'\n'*}; FAILED_COUNT=$((FAILED_COUNT + 0))
RUNNING_SVCS=$(systemctl list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | wc -l); RUNNING_SVCS=$((RUNNING_SVCS + 0))

# Firewall rules
FW_RULES=$(iptables -L -n 2>/dev/null | grep -c "^[A-Z]" || echo 0)

# Docker
DOCKER_RUNNING=0; DOCKER_STOPPED=0; DOCKER_UNHEALTHY=0; DOCKER_LINES=""
if command -v docker &>/dev/null; then
  DOCKER_DATA=$(docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null)
  while IFS=$'\t' read -r name status; do
    [ -z "$name" ] && continue
    case "$status" in
      *running*|Up*)
        DOCKER_RUNNING=$((DOCKER_RUNNING+1))
        if echo "$status" | grep -q "unhealthy"; then
          DOCKER_UNHEALTHY=$((DOCKER_UNHEALTHY+1))
          DOCKER_LINES+="  ${r}✗${N} ${D}${name}${N}\n"
        elif echo "$status" | grep -q "healthy"; then
          DOCKER_LINES+="  ${g}●${N} ${D}${name}${N}\n"
        else
          DOCKER_LINES+="  ${D}○ ${name}${N}\n"
        fi
        ;;
      *Restarting*)
        DOCKER_UNHEALTHY=$((DOCKER_UNHEALTHY+1))
        DOCKER_LINES+="  ${R}⟳${N} ${D}${name}${N}\n"
        ;;
      *) DOCKER_STOPPED=$((DOCKER_STOPPED+1)) ;;
    esac
  done <<< "$DOCKER_DATA"
fi

# Exposed ports
EXPOSED=$(ss -tlnp 2>/dev/null | awk 'NR>1 && $4 ~ /0\.0\.0\.0|::/ {split($4,a,":"); print a[length(a)]}' | sort -un | head -12 | tr '\n' ' ')

# HTB/VPN
HTB_IP=""
for iface in tun0 tun1; do
  TUN_IP=$(ip -4 addr show "$iface" 2>/dev/null | grep -oP 'inet \K[0-9./]+')
  [ -n "$TUN_IP" ] && { HTB_IP="$iface: $TUN_IP"; break; }
done

# WG transfer + handshakes
WG_RX=0; WG_TX=0
declare -A WG_HS
if [ -n "$WG_IF" ] && command -v wg &>/dev/null; then
  PEER_IP_TMP=""
  while IFS= read -r line; do
    [[ "$line" == *"allowed ips:"* ]] && PEER_IP_TMP=$(echo "$line" | awk '{print $3}' | cut -d/ -f1)
    [[ "$line" == *"latest handshake:"* ]] && WG_HS[$PEER_IP_TMP]="${line#*latest handshake: }"
  done < <(wg show "$WG_IF" 2>/dev/null)
  WG_XFER=$(wg show "$WG_IF" transfer 2>/dev/null | awk '{rx+=$2; tx+=$3} END{printf "%.0f %.0f", rx, tx}')
  WG_RX=$(echo "$WG_XFER" | awk '{print $1}')
  WG_TX=$(echo "$WG_XFER" | awk '{print $2}')
fi

# ── Wait for background jobs ──────────────────────────────────────────
wait 2>/dev/null

# Collect background results
[ -f /tmp/.motd-ts ] && . /tmp/.motd-ts && rm -f /tmp/.motd-ts
[ -f /tmp/.motd-sshfail ] && SSH_FAIL_24H=$(cat /tmp/.motd-sshfail) && rm -f /tmp/.motd-sshfail || SSH_FAIL_24H=0
UPD_STR="0;0"; [ -f /tmp/.motd-updates ] && UPD_STR=$(cat /tmp/.motd-updates) && rm -f /tmp/.motd-updates
SEC_UPDATES=$(echo "$UPD_STR" | cut -d';' -f2); REG_UPDATES=$(echo "$UPD_STR" | cut -d';' -f1)
NET_DATA=""; [ -f /tmp/.motd-net ] && NET_DATA=$(cat /tmp/.motd-net) && rm -f /tmp/.motd-net

# ── Helpers ────────────────────────────────────────────────────────────
bar() {
  local pct=$1 width=20 filled=$((${1} * 20 / 100)) color="$G"
  [ "$pct" -ge 60 ] && color="$Y"; [ "$pct" -ge 85 ] && color="$R"
  local empty=$((width - filled))
  printf "${color}"; for ((i=0;i<filled;i++)); do printf '█'; done
  printf "${D}"; for ((i=0;i<empty;i++)); do printf '░'; done; printf "${N}"
}

fmt_bytes() {
  local b=$1
  if [ "$b" -ge 1073741824 ]; then printf "%.1f GB" "$(echo "$b/1073741824" | bc -l 2>/dev/null || echo 0)"
  elif [ "$b" -ge 1048576 ]; then printf "%.1f MB" "$(echo "$b/1048576" | bc -l 2>/dev/null || echo 0)"
  elif [ "$b" -ge 1024 ]; then printf "%.1f KB" "$(echo "$b/1024" | bc -l 2>/dev/null || echo 0)"
  else printf "%d B" "$b"; fi
}

fmt_rate() {
  local r=$1
  if [ "$r" -ge 1048576 ]; then printf "%.1f MB/s" "$(echo "$r/1048576" | bc -l 2>/dev/null || echo 0)"
  elif [ "$r" -ge 1024 ]; then printf "%.1f KB/s" "$(echo "$r/1024" | bc -l 2>/dev/null || echo 0)"
  else printf "%d B/s" "$r"; fi
}

LOAD_INT=${LOAD1%.*}; [ -z "$LOAD_INT" ] && LOAD_INT=0
LOAD_PCT=$((LOAD_INT * 100 / CPU_CORES)); [ "$LOAD_PCT" -gt 100 ] && LOAD_PCT=100

# ══════════════════════════════════════════════════════════════════════
# RENDER
# ══════════════════════════════════════════════════════════════════════

echo ""
echo -e "${NC_COLOR} ██████╗██╗   ██╗██████╗ ███████╗██████╗ ███╗   ██╗ ██████╗ ██████╗ ██████╗ ${N}"
echo -e "${NC_COLOR}██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗████╗  ██║██╔═══██╗██╔══██╗██╔══██╗${N}"
echo -e "${NC_COLOR}██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝██╔██╗ ██║██║   ██║██████╔╝██║  ██║${N}"
echo -e "${NC_COLOR}██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗██║╚██╗██║██║   ██║██╔══██╗██║  ██║${N}"
echo -e "${NC_COLOR}╚██████╗   ██║   ██████╔╝███████╗██║  ██║██║ ╚████║╚██████╔╝██║  ██║██████╔╝${N}"
echo -e "${NC_COLOR} ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝  ╚═╝╚═════╝${N}"
echo ""
echo -e "  ${D}authorized security research workstation${N}  ${D}·${N}  ${C}VoidChecksum${N}  ${D}·${N}  ${D}$(date +%Y)${N}"
echo ""

# ── Header ─────────────────────────────────────────────────────────────
echo -e "$LINE"
printf "  ${NC_COLOR}${NODE_ICON} %-17s${N} ${D}│${N}  ${W}%-17s${N} ${D}│${N}  wg: %b  ${D}│${N}  ${D}%s${N}\n" \
    "$HOSTNAME_STR" "$PRIMARY_IP" \
    "$([ "$WG_STATUS" = "up" ] && echo -e "${G}up${N}" || echo -e "${R}down${N}")" \
    "$OS"
printf "  ${D}  %-17s${N} ${D}│${N}  ${D}%-17s${N} ${D}│${N}  ${NC_COLOR}%s${N}\n" \
    "" "$MY_WG_IP" "$NODE_ROLE"

# Extra IPs line (Tailscale + kernel)
TS_DISPLAY="${TS_IP:-}"
EXTRA=""
[ -n "$TS_DISPLAY" ] && [ "$TS_DISPLAY" != "none" ] && EXTRA="ts: ${TS_DISPLAY}  "
EXTRA+="kern: ${KERNEL}"
[ -n "$CPU_TEMP" ] && EXTRA+="  temp: ${CPU_TEMP}"
printf "  ${D}  %-17s${N} ${D}│${N}  ${D}%-17s${N} ${D}│${N}  ${D}%s${N}\n" \
    "" "" "$EXTRA"
echo -e "$LINE"
echo ""

# ── System bars ────────────────────────────────────────────────────────
printf "  ${W}LOAD${N}   $(bar $LOAD_PCT)  ${W}%s  %s  %s${N}  ${D}(%s cores)${N}\n" "$LOAD1" "$LOAD5" "$LOAD15" "$CPU_CORES"
printf "  ${W}MEM${N}    $(bar $MEM_PCT)  ${W}%sM${N} / ${D}%sM${N} ${D}(%s%%)${N}\n" "$MEM_USED_MB" "$MEM_TOTAL_MB" "$MEM_PCT"
printf "  ${W}DISK${N}   $(bar $DISK_PCT)  ${W}%s${N} / ${D}%s${N} ${D}(%s%%)${N}\n" "$DISK_USED" "$DISK_TOTAL" "$DISK_PCT"
printf "  ${W}SWAP${N}   $(bar $SWAP_PCT)  ${D}%s%%${N}\n" "$SWAP_PCT"
echo ""
printf "  ${W}UPTIME${N} %-18s ${W}PROCS${N} %-8s ${W}SESSIONS${N} %s\n" "$UPTIME_STR" "$PROCS" "$SESSIONS"
echo ""

# ── Top processes ──────────────────────────────────────────────────────
if [ -f /tmp/.motd-procs ]; then
  echo -e "$LINE"
  echo -e "  ${W}TOP PROCESSES${N}"
  while read -r user cpu mem cmd; do
    [ -z "$user" ] && continue
    cmd_short=$(basename "$cmd" 2>/dev/null | cut -c1-25)
    printf "    ${D}%-10s${N} ${Y}%4s cpu${N}  ${C}%4s mem${N}  ${D}%s${N}\n" "$user" "$cpu" "$mem" "$cmd_short"
  done < /tmp/.motd-procs
  rm -f /tmp/.motd-procs
  echo ""
fi

# ── Docker ─────────────────────────────────────────────────────────────
if [ "$DOCKER_RUNNING" -gt 0 ] || [ "$DOCKER_STOPPED" -gt 0 ]; then
  echo -e "$LINE"
  HEALTH_STR=""
  [ "$DOCKER_UNHEALTHY" -gt 0 ] && HEALTH_STR="  ${R}${DOCKER_UNHEALTHY} unhealthy${N}"
  printf "  ${W}DOCKER${N}   ${G}%s running${N}  ${D}·${N}  ${D}%s stopped${N}%b\n" "$DOCKER_RUNNING" "$DOCKER_STOPPED" "$HEALTH_STR"
  echo -ne "  ${D}        ${N}"
  # Compact container grid (4 per row)
  COL=0
  while IFS= read -r cline; do
    [ -z "$cline" ] && continue
    echo -ne " $cline"
    COL=$((COL+1))
    [ $((COL % 4)) -eq 0 ] && echo -ne "\n  ${D}        ${N}"
  done <<< "$(echo -e "$DOCKER_LINES")"
  [ $((COL % 4)) -ne 0 ] && echo ""
  echo ""
fi

# ── Services ───────────────────────────────────────────────────────────
echo -e "$LINE"
printf "  ${W}SERVICES${N} ${G}%s running${N}" "$RUNNING_SVCS"
if [ "$FAILED_COUNT" -gt 0 ]; then
  printf "  ${D}·${N}  ${R}%s failed${N}\n" "$FAILED_COUNT"
  echo "$FAILED_SVCS" | head -4 | while read -r line; do
    svc_name=$(echo "$line" | awk '{print $2}' | sed 's/\.service//')
    [ -n "$svc_name" ] && printf "    ${R}✗${N} ${D}%s${N}\n" "$svc_name"
  done
else
  echo ""
fi
echo ""

# ── Security ───────────────────────────────────────────────────────────
echo -e "$LINE"
SSH_COL="$G"; [ "$SSH_FAIL_24H" -gt 0 ] && SSH_COL="$Y"; [ "$SSH_FAIL_24H" -gt 50 ] && SSH_COL="$R"
printf "  ${W}SSH${N}      ${SSH_COL}%s failed${N} ${D}(24h)${N}  ${D}·${N}  ${D}%s fw rules${N}" "$SSH_FAIL_24H" "$FW_RULES"
[ -n "$LAST_LOGIN" ] && printf "  ${D}·${N}  ${D}last: %s${N}" "$LAST_LOGIN"
echo ""
[ -n "$EXPOSED" ] && printf "  ${W}PORTS${N}    ${D}%s${N}\n" "$EXPOSED"
echo ""

# ── Network ────────────────────────────────────────────────────────────
echo -e "$LINE"
if [ -n "$NET_DATA" ]; then
  N_IF=$(echo "$NET_DATA" | grep -oP 'ETH_IF=\K\S+')
  N_RX=$(echo "$NET_DATA" | grep -oP 'RX=\K\S+')
  N_TX=$(echo "$NET_DATA" | grep -oP 'TX=\K\S+')
  printf "  ${W}NET${N}      ${G}▲ %s${N}  ${C}▼ %s${N}   ${D}%s${N}\n" "$(fmt_rate ${N_TX:-0})" "$(fmt_rate ${N_RX:-0})" "$N_IF"
fi
if [ "$WG_TX" -gt 0 ] || [ "$WG_RX" -gt 0 ]; then
  printf "  ${W}WG${N}       ${G}▲ %s${N}  ${C}▼ %s${N}   ${D}%s (session)${N}\n" "$(fmt_bytes ${WG_TX:-0})" "$(fmt_bytes ${WG_RX:-0})" "$WG_IF"
fi
echo ""

# ── Updates ────────────────────────────────────────────────────────────
if [ "${SEC_UPDATES:-0}" -gt 0 ] || [ "${REG_UPDATES:-0}" -gt 0 ]; then
  echo -e "$LINE"
  if [ "${SEC_UPDATES:-0}" -gt 0 ]; then
    printf "  ${W}UPDATES${N}  ${R}%s security${N}  ${D}·${N}  ${D}%s regular${N}\n" "$SEC_UPDATES" "$REG_UPDATES"
  else
    printf "  ${W}UPDATES${N}  ${D}%s regular${N}\n" "$REG_UPDATES"
  fi
  echo ""
fi

# ── HTB ────────────────────────────────────────────────────────────────
if [ -n "$HTB_IP" ]; then
  echo -e "$LINE"
  printf "  ${W}HTB${N}      ${G}%s${N}\n" "$HTB_IP"
  echo ""
fi

# ── WireGuard Mesh ─────────────────────────────────────────────────────
declare -A WG_NODES=(["contabo-vps"]="10.10.0.1" ["hostinger-vps"]="10.10.0.2" ["windows-pc"]="10.10.0.3" ["thinkpad-t14"]="10.10.0.4")
WG_ORDER=("contabo-vps" "hostinger-vps" "windows-pc" "thinkpad-t14")
declare -A WG_ROLES=(["contabo-vps"]="storage" ["hostinger-vps"]="compute" ["windows-pc"]="controller" ["thinkpad-t14"]="gpu")
declare -A WG_COLORS=(["contabo-vps"]="$R" ["hostinger-vps"]="$M" ["windows-pc"]="$B" ["thinkpad-t14"]="$G")

echo -e "$LINE"
echo -e "  ${W}WIREGUARD MESH${N}  ${D}(${WG_IF:-none})${N}"
echo ""

for name in "${WG_ORDER[@]}"; do
  ip="${WG_NODES[$name]}"
  clr="${WG_COLORS[$name]:-$D}"
  role="${WG_ROLES[$name]:-}"
  hs="${WG_HS[$ip]:-}"

  if [ "$ip" = "$MY_WG_IP" ]; then
    printf "    ${clr}%-18s${N} %-16s ${C}● this node${N}    ${D}%s${N}\n" "$name" "$ip" "$role"
  else
    lat=""; [ -f "/tmp/.motd-ping-$name" ] && lat=$(cat "/tmp/.motd-ping-$name") && rm -f "/tmp/.motd-ping-$name"

    if [ -n "$lat" ] && [ "$lat" != "FAIL" ]; then
      lat_int=${lat%.*}
      if [ "${lat_int:-999}" -lt 5 ]; then lat_clr="$G"
      elif [ "${lat_int:-999}" -lt 50 ]; then lat_clr="$Y"
      else lat_clr="$D"; fi

      hs_str=""
      if [ -n "$hs" ]; then
        if echo "$hs" | grep -qE "^[0-9]+ seconds?$|^[12] minutes?$"; then
          hs_str="${D}(${hs})${N}"
        else
          hs_str="${Y}(${hs})${N}"
        fi
      fi
      printf "    ${clr}%-18s${N} %-16s ${G}● online${N}  ${lat_clr}%6s${N}  ${D}%-10s${N} %b\n" "$name" "$ip" "${lat}ms" "$role" "$hs_str"
    else
      printf "    ${D}%-18s %-16s ○ offline${N}         ${D}%s${N}\n" "$name" "$ip" "$role"
    fi
  fi
done

echo ""
echo -e "$LINE"

# ── Warnings ───────────────────────────────────────────────────────────
WARNED=0
[ "$DISK_PCT" -ge 90 ] && echo -e "  ${R}⚠  DISK CRITICAL: ${DISK_PCT}%${N}" && WARNED=1
[ "$MEM_PCT" -ge 90 ] && echo -e "  ${R}⚠  MEMORY CRITICAL: ${MEM_PCT}%${N}" && WARNED=1
[ "$DOCKER_UNHEALTHY" -gt 0 ] && echo -e "  ${R}⚠  ${DOCKER_UNHEALTHY} UNHEALTHY CONTAINER(S)${N}" && WARNED=1
[ "$FAILED_COUNT" -gt 0 ] && echo -e "  ${Y}⚠  ${FAILED_COUNT} FAILED SERVICE(S)${N}" && WARNED=1
[ -f /var/run/reboot-required ] && echo -e "  ${Y}⚠  REBOOT REQUIRED${N}" && WARNED=1
[ $WARNED -eq 1 ] && echo -e "$LINE"
echo ""
